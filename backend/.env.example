# Copy Match Checker — server environment. Copy to .env and fill in.
# serve.py loads this file itself on startup (no python-dotenv dependency).

# Required for the AI comparison + page segmentation endpoints.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-sonnet-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# Split deploy only. Origin(s) of the standalone front (comma-separated), e.g.
# the Cloudflare Pages URL. When set, CORS echoes the exact origin and allows
# credentials (the Cloudflare Access cookie). Leave empty for same-origin/local
# dev (CORS falls back to open "*", no credentials). Not needed with the Pages
# Function proxy (the browser is same-origin with pages.dev).
# ALLOWED_ORIGIN=https://copymatch.pages.dev,https://copyqa.yourdomain.com

# Pages Function proxy deploy. Shared secret the Cloudflare Pages Function sends
# as X-Proxy-Secret; serve.py rejects /render and /ai/* without it, so the VPS
# IP can't be abused directly. Must match PROXY_SECRET set in the Pages project.
# Leave empty for local dev. Generate with: openssl rand -hex 32
# PROXY_SECRET=

# Postgres connection (not used by serve.py yet — reserved for the Phase 2 data
# layer: history, projects, per-client dictionaries). On the VPS it points at a
# local-only Postgres 16 (localhost, not internet-exposed).
# DATABASE_URL=postgresql://copymatch:PASSWORD@localhost:5432/copymatch
